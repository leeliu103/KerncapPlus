@@ -179,0 +188,55 @@ def generate_hsaco_reproducer(
+def _build_recompile_argv(kernel_source: KernelSource) -> List[str]:
+    """Return the original compile argv without compile-only/output flags."""
+    tokens = shlex.split(kernel_source.compile_command)
+    new_tokens = []
+    skip_next = False
+    for tok in tokens:
+        if skip_next:
+            skip_next = False
+            continue
+        if tok == "-c":
+            continue
+        if tok == "-o":
+            skip_next = True
+            continue
+        if tok.startswith("-o") and len(tok) > 2:
+            continue
+        new_tokens.append(tok)
+    return new_tokens
+
+
+def _write_workspace_manifest(
+    path: str,
+    kernel_name: str,
+    gpu_arch: str,
+    kernel_source: Optional[KernelSource],
+    metadata: dict,
+) -> None:
+    """Write compile metadata for tools that need exact source replay."""
+    if not kernel_source or not kernel_source.compile_command or not kernel_source.compile_dir:
+        return
+
+    mangled_name = str(metadata.get("mangled_name", "")).strip()
+    if not mangled_name:
+        return
+
+    compile_argv = _build_recompile_argv(kernel_source)
+    if not compile_argv:
+        return
+
+    payload = {
+        "schema_version": 1,
+        "producer": "kerncap",
+        "kernel_name": metadata.get("kernel_name", kernel_name),
+        "demangled_name": metadata.get("demangled_name", kernel_name),
+        "mangled_name": mangled_name,
+        "gpu_arch": gpu_arch,
+        "compile_dir": os.path.abspath(kernel_source.compile_dir),
+        "compile_argv": compile_argv,
+    }
+
+    with open(path, "w") as f:
+        json.dump(payload, f, indent=2)
+        f.write("\n")
+
+
